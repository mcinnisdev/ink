---
layout: base.njk
---
<section class="section">
  <div class="container container--narrow">

    {# Header #}
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-100 mb-2">
        <i data-lucide="blocks" class="icon-heading"></i> {{ title }}
      </h1>
      {% if excerpt %}
      <p class="text-gray-400 mb-4">{{ excerpt }}</p>
      {% endif %}
      {% if content | trim %}
      <div class="text-gray-300 leading-relaxed mb-8">
        {{ content | safe }}
      </div>
      {% endif %}
    </div>

    {# Category Filter #}
    <div class="mb-8 flex flex-wrap gap-2" id="component-filters">
      <button class="component-filter active" data-filter="all">All</button>
      <button class="component-filter" data-filter="marketing">Marketing</button>
      <button class="component-filter" data-filter="content">Content</button>
      <button class="component-filter" data-filter="interaction">Interaction</button>
    </div>

    {# Component Grid #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="component-grid">
      {% for component in components %}
      <div
        class="component-card bg-gray-900 border border-gray-800 border-l-[3px] border-l-coral rounded-xl p-5 flex flex-col gap-4"
        data-category="{{ component.category }}"
      >
        {# Header row: icon + name + category badge #}
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-coral/10 flex items-center justify-center flex-shrink-0">
            <i data-lucide="{{ component.icon }}" class="text-coral" style="width:1.1em;height:1.1em;stroke-width:2"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-base font-semibold text-gray-100 leading-snug">{{ component.label }}</h2>
            <span class="inline-block mt-0.5 text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded bg-gray-800 text-gray-400">{{ component.category }}</span>
          </div>
        </div>

        {# Description #}
        <p class="text-sm text-gray-400 leading-relaxed">{{ component.description }}</p>

        {# Use cases #}
        <div class="flex flex-wrap gap-1.5">
          {% for use_case in component.use_cases %}
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400">{{ use_case }}</span>
          {% endfor %}
        </div>

        {# CLI command copy block #}
        <div class="mt-auto pt-1">
          <div class="flex items-center gap-2 bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 font-mono text-sm text-gray-300">
            <span class="text-coral select-none">$</span>
            <span class="flex-1 text-gray-200">{{ component.cli_command }}</span>
            <button
              class="copy-btn flex-shrink-0 text-gray-500 hover:text-coral transition-colors"
              data-command="{{ component.cli_command }}"
              aria-label="Copy command"
              title="Copy command"
            >
              <i data-lucide="copy" style="width:0.9em;height:0.9em;stroke-width:2"></i>
            </button>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    {# Bottom CTA #}
    <div class="mt-16 text-center border-t border-gray-800 pt-12">
      <p class="text-gray-400 mb-4">Don't see what you need?</p>
      <a href="https://github.com/mcinnisdev/ink/issues/new" class="btn-outline">
        <i data-lucide="plus-circle" class="icon-sm"></i>
        Request a component
      </a>
    </div>

  </div>
</section>

<style>
  .component-filter {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid rgb(31 41 55);
    background: transparent;
    color: rgb(156 163 175);
    cursor: pointer;
    transition: all 150ms;
  }
  .component-filter:hover {
    border-color: #e07850;
    color: #e07850;
  }
  .component-filter.active {
    background: #e07850;
    border-color: #e07850;
    color: #fff;
  }
  .component-card {
    transition: border-color 200ms, transform 150ms;
  }
  .component-card:hover {
    border-color: #e07850;
  }
  .component-card[hidden] {
    display: none;
  }
</style>

<script>
  (function () {
    // Category filter
    const filters = document.querySelectorAll('.component-filter');
    const cards = document.querySelectorAll('.component-card');

    filters.forEach(function (btn) {
      btn.addEventListener('click', function () {
        const filter = btn.dataset.filter;

        filters.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');

        cards.forEach(function (card) {
          if (filter === 'all' || card.dataset.category === filter) {
            card.removeAttribute('hidden');
          } else {
            card.setAttribute('hidden', '');
          }
        });
      });
    });

    // Copy command
    document.querySelectorAll('.copy-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const command = btn.dataset.command;
        navigator.clipboard.writeText(command).then(function () {
          const icon = btn.querySelector('i');
          if (icon) {
            icon.setAttribute('data-lucide', 'check');
            if (window.lucide) window.lucide.createIcons();
          }
          btn.style.color = '#4ade80';
          setTimeout(function () {
            if (icon) {
              icon.setAttribute('data-lucide', 'copy');
              if (window.lucide) window.lucide.createIcons();
            }
            btn.style.color = '';
          }, 1500);
        });
      });
    });
  })();
</script>
