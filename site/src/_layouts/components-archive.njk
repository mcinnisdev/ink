---
layout: base.njk
---

{# ── Import all component macros ── #}
{% from "component-previews/contact-form.njk"      import contactForm %}
{% from "component-previews/feature-grid.njk"      import featureGrid %}
{% from "component-previews/image-gallery.njk"     import imageGallery %}
{% from "component-previews/logo-cloud.njk"        import logoCloud %}
{% from "component-previews/modal.njk"             import modalTrigger, modal %}
{% from "component-previews/newsletter-signup.njk" import newsletterSignup %}
{% from "component-previews/pricing-table.njk"     import pricingTable %}
{% from "component-previews/social-share.njk"      import socialShare %}
{% from "component-previews/stats-counter.njk"     import statsCounter %}
{% from "component-previews/tabs.njk"              import tabs %}
{% from "component-previews/testimonials.njk"      import testimonialGrid %}
{% from "component-previews/timeline.njk"          import timeline %}

