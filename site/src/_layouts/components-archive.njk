{# ── Macro: render a component's preview HTML by id ── #}
{% macro renderPreview(id, fullSize) %}
  {% if id === "contact-form" %}
    {{ contactForm("#", "POST", _contactFormFields, "Send Message") }}
  {% elif id === "feature-grid" %}
    {{ featureGrid(_featureGridItems, 3) }}
  {% elif id === "image-gallery" %}
    {{ imageGallery(_galleryImages, 3, "gallery-" + ("fs" if fullSize else "thumb")) }}
  {% elif id === "logo-cloud" %}
    {{ logoCloud(_logoCloudLogos, "Trusted by teams everywhere") }}
  {% elif id === "modal" %}
    <div class="modal-inline">
      <div class="modal-inline__header">
        <span class="modal-inline__title">Confirm Action</span>
        <button class="modal-inline__close">&times;</button>
      </div>
      <div class="modal-inline__body">
        <p>Are you sure you want to continue? This action can be undone from your dashboard.</p>
      </div>
      <div class="modal-inline__footer">
        <button class="comp-btn comp-btn--secondary">Cancel</button>
        <button class="comp-btn comp-btn--primary">Confirm</button>
      </div>
    </div>
  {% elif id === "newsletter-signup" %}
    {{ newsletterSignup("#", "Stay in the loop", "Get the latest updates delivered straight to your inbox.", "you@example.com", "Subscribe") }}
  {% elif id === "pricing-table" %}
    {{ pricingTable(_pricingPlans) }}
  {% elif id === "social-share" %}
    {{ socialShare("Check out Ink — the static site builder", "/", "https://get.ink") }}
  {% elif id === "stats-counter" %}
    {{ statsCounter(_statsItems) }}
  {% elif id === "tabs" %}
    {{ tabs(_tabsItems, ("fs-tabs" if fullSize else "thumb-tabs")) }}
  {% elif id === "testimonials" %}
    {{ testimonialGrid(_testimonialItems) }}
  {% elif id === "timeline" %}
    {{ timeline(_timelineItems) }}
  {% endif %}
{% endmacro %}

{# ────────────────────────────────────────────────── PAGE ── #}
<section class="section">
  <div class="container container--narrow">

    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-100 mb-2">
        <i data-lucide="blocks" class="icon-heading"></i> {{ title }}
      </h1>
      {% if excerpt %}<p class="text-gray-400 mb-4">{{ excerpt }}</p>{% endif %}
      {% if content | trim %}<div class="text-gray-300 leading-relaxed mb-8">{{ content | safe }}</div>{% endif %}
    </div>

    {# Category filter #}
    <div class="mb-8 flex flex-wrap gap-2" id="component-filters">
      <button class="component-filter active" data-filter="all">All</button>
      <button class="component-filter" data-filter="marketing">Marketing</button>
      <button class="component-filter" data-filter="content">Content</button>
      <button class="component-filter" data-filter="interaction">Interaction</button>
    </div>

    {# Component grid #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="component-grid">
      {% for component in components %}
      <div
        class="component-card bg-gray-900 border border-gray-800 border-l-[3px] border-l-coral rounded-xl overflow-hidden flex flex-col"
        data-category="{{ component.category }}"
      >
        {# Thumbnail preview frame #}
        <div class="preview-frame" data-component-id="{{ component.id }}" data-component-label="{{ component.label }}">
          <div class="preview-thumb">
            {{ renderPreview(component.id, false) }}
          </div>
          <div class="preview-fade"></div>
          <button class="preview-expand-btn" aria-label="View {{ component.label }} full size">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            Preview
          </button>
        </div>

        {# Card meta #}
        <div class="px-5 pb-5 pt-4 flex flex-col gap-3 flex-1">
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-coral/10 flex items-center justify-center flex-shrink-0">
              <i data-lucide="{{ component.icon }}" class="text-coral" style="width:1em;height:1em;stroke-width:2"></i>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="text-base font-semibold text-gray-100 leading-snug">{{ component.label }}</h2>
              <span class="inline-block mt-0.5 text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded bg-gray-800 text-gray-400">{{ component.category }}</span>
            </div>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">{{ component.description }}</p>
          <div class="flex flex-wrap gap-1.5">
            {% for use_case in component.use_cases %}
            <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400">{{ use_case }}</span>
            {% endfor %}
          </div>
          <div class="mt-auto pt-1">
            <div class="flex items-center gap-2 bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 font-mono text-sm">
              <span class="text-coral select-none">$</span>
              <span class="flex-1 text-gray-200">{{ component.cli_command }}</span>
              <button class="copy-btn flex-shrink-0 text-gray-500 hover:text-coral transition-colors" data-command="{{ component.cli_command }}" aria-label="Copy command">
                <i data-lucide="copy" style="width:0.9em;height:0.9em;stroke-width:2"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="mt-16 text-center border-t border-gray-800 pt-12">
      <p class="text-gray-400 mb-4">Don't see what you need?</p>
      <a href="https://github.com/mcinnisdev/ink/issues/new" class="btn-outline">
        <i data-lucide="plus-circle" class="icon-sm"></i>
        Request a component
      </a>
    </div>

  </div>
</section>

{# ── Hidden full-size preview store (one div per component) ── #}
<div id="fullsize-store" aria-hidden="true" style="display:none">
  {% for component in components %}
  <div id="fs-{{ component.id }}">
    {{ renderPreview(component.id, true) }}
  </div>
  {% endfor %}
</div>

{# ── Fullscreen preview modal ── #}
<div id="cp-modal" role="dialog" aria-modal="true" aria-labelledby="cp-modal-title" hidden>
  <div id="cp-modal-overlay"></div>
  <div id="cp-modal-window">
    <div id="cp-modal-header">
      <div id="cp-modal-chrome">
        <span class="cp-chrome-dot cp-chrome-dot--red"></span>
        <span class="cp-chrome-dot cp-chrome-dot--yellow"></span>
        <span class="cp-chrome-dot cp-chrome-dot--green"></span>
        <span id="cp-modal-title" class="cp-chrome-title"></span>
      </div>
      <button id="cp-modal-close" aria-label="Close preview">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cp-modal-body">
      <div id="cp-modal-content"></div>
    </div>
  </div>
</div>

<style>
/* ============================================================
   Preview frame thumbnail
   ============================================================ */
.preview-frame {
  position: relative;
  height: 240px;
  overflow: hidden;
  background: #0b1120;
  border-bottom: 1px solid rgb(31 41 55);
  cursor: pointer;
}

.preview-thumb {
  padding: 1.25rem;
  font-size: 0.875rem;
  pointer-events: none;
  user-select: none;
}

.preview-fade {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 100px;
  background: linear-gradient(transparent, #0b1120);
  pointer-events: none;
}

/* Expand button — always visible but more prominent on hover */
.preview-expand-btn {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0.375rem 0.875rem;
  background: rgba(11,17,32,0.85);
  border: 1px solid rgb(55 65 81);
  border-radius: 9999px;
  color: #9ca3af;
  font-size: 0.75rem;
  font-weight: 500;
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: background 150ms, border-color 150ms, color 150ms, opacity 150ms;
  opacity: 0.7;
  z-index: 2;
}
.preview-frame:hover .preview-expand-btn {
  opacity: 1;
  border-color: #e07850;
  color: #e07850;
}

/* ============================================================
   Fullscreen preview modal
   ============================================================ */
#cp-modal {
  position: fixed;
  inset: 0;
  z-index: 9500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
}
#cp-modal[hidden] { display: none; }

#cp-modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(6px);
}

#cp-modal-window {
  position: relative;
  width: 100%;
  max-width: 920px;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 32px 64px rgba(0,0,0,0.7);
  border: 1px solid rgb(55 65 81);
  animation: modal-in 180ms ease-out;
}
@keyframes modal-in {
  from { opacity: 0; transform: translateY(12px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0)   scale(1); }
}

/* Browser-chrome header */
#cp-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1rem;
  height: 44px;
  background: #1a2030;
  border-bottom: 1px solid rgb(31 41 55);
  flex-shrink: 0;
}

#cp-modal-chrome {
  display: flex;
  align-items: center;
  gap: 6px;
}

.cp-chrome-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}
.cp-chrome-dot--red    { background: #ff5f57; }
.cp-chrome-dot--yellow { background: #febc2e; }
.cp-chrome-dot--green  { background: #28c840; }

#cp-modal-title {
  margin-left: 12px;
  font-size: 0.8125rem;
  font-weight: 500;
  color: #9ca3af;
}

#cp-modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 6px;
  background: transparent;
  border: none;
  color: #6b7280;
  cursor: pointer;
  transition: background 150ms, color 150ms;
}
#cp-modal-close:hover { background: rgb(31 41 55); color: #f3f4f6; }

/* Modal scrollable body */
#cp-modal-body {
  flex: 1;
  overflow-y: auto;
  background: #030712;
  padding: 3rem 2.5rem;
}
#cp-modal-content { max-width: 800px; margin: 0 auto; }

/* ============================================================
   Shared component CSS scope — applies in BOTH thumbnail
   (.preview-thumb) and fullscreen modal (#cp-modal-content)
   ============================================================ */

/* --- Button aliases (.btn--primary/.btn--secondary from CLI templates) --- */
.preview-thumb .btn,
#cp-modal-content .btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 0.375rem; padding: 0.5rem 1.25rem; border-radius: 0.5rem;
  font-weight: 500; font-size: 0.875rem; text-decoration: none;
  cursor: pointer; border: 1px solid transparent;
  transition: background 150ms, color 150ms, border-color 150ms;
}
.preview-thumb .btn--primary,
#cp-modal-content .btn--primary,
.comp-btn--primary {
  background: #e07850; color: #fff; border-color: #e07850;
}
.preview-thumb .btn--primary:hover,
#cp-modal-content .btn--primary:hover,
.comp-btn--primary:hover { background: #c5623a; }

.preview-thumb .btn--secondary,
#cp-modal-content .btn--secondary,
.comp-btn--secondary {
  background: transparent; color: #d1d5db; border-color: #374151;
}
.preview-thumb .btn--secondary:hover,
#cp-modal-content .btn--secondary:hover,
.comp-btn--secondary:hover { border-color: #6b7280; color: #f3f4f6; }

/* Base .comp-btn for modal-inline */
.comp-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 0.375rem; padding: 0.5rem 1.25rem; border-radius: 0.5rem;
  font-weight: 500; font-size: 0.875rem; text-decoration: none;
  cursor: pointer; border: 1px solid transparent;
  transition: background 150ms, color 150ms, border-color 150ms;
}

/* --- Testimonials --- */
.preview-thumb .testimonial-grid,
#cp-modal-content .testimonial-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.25rem;
}
.preview-thumb .testimonial,
#cp-modal-content .testimonial {
  background: #1f2937; border: 1px solid #374151;
  border-radius: 0.875rem; padding: 1.5rem;
}
.preview-thumb .testimonial__rating,
#cp-modal-content .testimonial__rating { margin-bottom: 0.5rem; }
.preview-thumb .testimonial__star,
#cp-modal-content .testimonial__star { color: #f59e0b; font-size: 1.125rem; }
.preview-thumb .testimonial__quote,
#cp-modal-content .testimonial__quote {
  font-style: italic; font-size: 0.9375rem; line-height: 1.65;
  color: #d1d5db; margin-bottom: 1rem;
}
.preview-thumb .testimonial__quote::before,
#cp-modal-content .testimonial__quote::before {
  content: "\201C"; font-size: 1.5rem; color: #e07850; font-weight: 700;
  line-height: 0; vertical-align: -0.2em; margin-right: 0.1em;
}
.preview-thumb .testimonial__author,
#cp-modal-content .testimonial__author { display: flex; align-items: center; gap: 0.625rem; }
.preview-thumb .testimonial__name,
#cp-modal-content .testimonial__name { display: block; font-weight: 600; font-style: normal; color: #f3f4f6; font-size: 0.9rem; }
.preview-thumb .testimonial__role,
#cp-modal-content .testimonial__role { display: block; font-size: 0.8125rem; color: #9ca3af; }

/* --- Gallery --- */
.preview-thumb .gallery,
#cp-modal-content .gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.625rem;
}
.preview-thumb .gallery__link,
#cp-modal-content .gallery__link { display: block; border-radius: 0.5rem; overflow: hidden; }
.preview-thumb .gallery__img,
#cp-modal-content .gallery__img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; }
.preview-thumb .lightbox,
#cp-modal-content .lightbox { display: none; }

/* --- Pricing table --- */
.preview-thumb .pricing-table,
#cp-modal-content .pricing-table {
  display: flex; gap: 1rem;
  align-items: flex-start; justify-content: center; flex-wrap: wrap;
}
.preview-thumb .pricing-card,
#cp-modal-content .pricing-card {
  flex: 1; min-width: 220px; max-width: 300px;
  background: #1f2937; border: 1px solid #374151;
  border-radius: 0.875rem; padding: 1.5rem;
  text-align: center; display: flex; flex-direction: column; position: relative;
}
.preview-thumb .pricing-card--featured,
#cp-modal-content .pricing-card--featured {
  border-color: #e07850; border-width: 2px; transform: scale(1.04);
  box-shadow: 0 8px 30px rgba(224,120,80,0.2);
}
.preview-thumb .pricing-card__badge,
#cp-modal-content .pricing-card__badge {
  position: absolute; top: -11px; left: 50%; transform: translateX(-50%);
  background: #e07850; color: #fff; font-size: 0.6875rem; font-weight: 600;
  padding: 0.125rem 0.7rem; border-radius: 9999px; white-space: nowrap;
}
.preview-thumb .pricing-card__name,
#cp-modal-content .pricing-card__name { font-size: 1rem; font-weight: 700; color: #f3f4f6; margin-bottom: 0.375rem; }
.preview-thumb .pricing-card__amount,
#cp-modal-content .pricing-card__amount { font-size: 2rem; font-weight: 800; color: #f3f4f6; }
.preview-thumb .pricing-card__period,
#cp-modal-content .pricing-card__period { font-size: 0.8125rem; color: #9ca3af; }
.preview-thumb .pricing-card__desc,
#cp-modal-content .pricing-card__desc { font-size: 0.8125rem; color: #9ca3af; margin: 0.5rem 0 0.875rem; }
.preview-thumb .pricing-card__features,
#cp-modal-content .pricing-card__features { list-style: none; text-align: left; margin-bottom: 1rem; flex-grow: 1; }
.preview-thumb .pricing-card__features li,
#cp-modal-content .pricing-card__features li {
  padding: 0.3rem 0; border-bottom: 1px solid rgba(255,255,255,0.06);
  font-size: 0.8125rem; color: #d1d5db;
}
.preview-thumb .pricing-card__features li::before,
#cp-modal-content .pricing-card__features li::before { content: "✓ "; color: #e07850; font-weight: 700; }
.preview-thumb .pricing-card .btn,
#cp-modal-content .pricing-card .btn { width: 100%; margin-top: auto; }

/* --- Timeline --- */
.preview-thumb .timeline,
#cp-modal-content .timeline { position: relative; padding-left: 2.5rem; }
.preview-thumb .timeline::before,
#cp-modal-content .timeline::before {
  content: ""; position: absolute; left: 14px; top: 0; bottom: 0;
  width: 2px; background: #374151;
}
.preview-thumb .timeline__item,
#cp-modal-content .timeline__item { position: relative; padding-bottom: 1.5rem; }
.preview-thumb .timeline__item:last-child,
#cp-modal-content .timeline__item:last-child { padding-bottom: 0; }
.preview-thumb .timeline__marker,
#cp-modal-content .timeline__marker { position: absolute; left: -2.5rem; top: 0.3rem; }
.preview-thumb .timeline__marker::before,
#cp-modal-content .timeline__marker::before {
  content: ""; width: 12px; height: 12px; border-radius: 50%;
  background: #e07850; border: 2px solid #030712;
  box-shadow: 0 0 0 2px #e07850; position: absolute; left: calc(14px - 6px);
}
.preview-thumb .timeline__year,
#cp-modal-content .timeline__year {
  font-size: 0.8125rem; font-weight: 700; color: #e07850;
  margin-bottom: 0.3rem; display: block;
}
.preview-thumb .timeline__content,
#cp-modal-content .timeline__content {
  background: #1f2937; border: 1px solid #374151;
  border-radius: 0.625rem; padding: 0.875rem 1.125rem;
}
.preview-thumb .timeline__title,
#cp-modal-content .timeline__title { font-size: 0.9375rem; font-weight: 600; color: #f3f4f6; margin-bottom: 0.2rem; }
.preview-thumb .timeline__description,
#cp-modal-content .timeline__description { font-size: 0.8125rem; color: #9ca3af; line-height: 1.55; }

/* --- Logo cloud --- */
.preview-thumb .logo-cloud,
#cp-modal-content .logo-cloud { padding: 1.5rem 0.5rem; text-align: center; }
.preview-thumb .logo-cloud__heading,
#cp-modal-content .logo-cloud__heading {
  font-size: 0.8125rem; color: #6b7280; text-transform: uppercase;
  letter-spacing: 0.08em; margin-bottom: 1.25rem;
}
.preview-thumb .logo-cloud__grid,
#cp-modal-content .logo-cloud__grid {
  display: flex; flex-wrap: wrap; align-items: center;
  justify-content: center; gap: 1rem 1.5rem;
}
.preview-thumb .logo-cloud__img,
#cp-modal-content .logo-cloud__img { max-height: 32px; width: auto; opacity: 0.55; filter: grayscale(1); }

/* --- Modal inline (used for the "Modal" component card) --- */
.modal-inline {
  background: #1f2937; border: 1px solid #374151;
  border-radius: 0.875rem; max-width: 480px; margin: 0 auto;
  box-shadow: 0 16px 48px rgba(0,0,0,0.5);
}
.modal-inline__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.25rem; border-bottom: 1px solid #374151;
}
.modal-inline__title { font-size: 1rem; font-weight: 700; color: #f3f4f6; }
.modal-inline__close {
  background: none; border: none; font-size: 1.5rem;
  cursor: pointer; color: #9ca3af; line-height: 1; padding: 0 0.25rem;
  border-radius: 0.375rem;
}
.modal-inline__close:hover { color: #f3f4f6; }
.modal-inline__body { padding: 1.25rem; font-size: 0.9rem; color: #d1d5db; line-height: 1.6; }
.modal-inline__footer {
  display: flex; gap: 0.5rem; justify-content: flex-end;
  padding: 0.875rem 1.25rem 1.125rem; border-top: 1px solid #374151;
}

/* ============================================================
   Category filter buttons + card hover
   ============================================================ */
.component-filter {
  padding: 0.375rem 0.875rem; border-radius: 9999px; font-size: 0.8125rem;
  font-weight: 500; border: 1px solid rgb(31 41 55); background: transparent;
  color: rgb(156 163 175); cursor: pointer; transition: all 150ms;
}
.component-filter:hover { border-color: #e07850; color: #e07850; }
.component-filter.active { background: #e07850; border-color: #e07850; color: #fff; }

.component-card { transition: border-color 200ms; }
.component-card:hover { border-color: #e07850; }
.component-card[hidden] { display: none; }
</style>

<script>
(function () {

  /* ── Category filter ── */
  var filters = document.querySelectorAll('.component-filter');
  var cards   = document.querySelectorAll('.component-card');

  filters.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var filter = btn.dataset.filter;
      filters.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      cards.forEach(function (card) {
        if (filter === 'all' || card.dataset.category === filter) {
          card.removeAttribute('hidden');
        } else {
          card.setAttribute('hidden', '');
        }
      });
    });
  });

  /* ── Copy CLI command ── */
  document.querySelectorAll('.copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(btn.dataset.command).then(function () {
        var icon = btn.querySelector('i');
        if (icon) { icon.setAttribute('data-lucide', 'check'); if (window.lucide) window.lucide.createIcons(); }
        btn.style.color = '#4ade80';
        setTimeout(function () {
          if (icon) { icon.setAttribute('data-lucide', 'copy'); if (window.lucide) window.lucide.createIcons(); }
          btn.style.color = '';
        }, 1500);
      });
    });
  });

  /* ── Fullscreen component preview modal ── */
  var modal    = document.getElementById('cp-modal');
  var overlay  = document.getElementById('cp-modal-overlay');
  var content  = document.getElementById('cp-modal-content');
  var titleEl  = document.getElementById('cp-modal-title');
  var closeBtn = document.getElementById('cp-modal-close');

  function openModal(id, label) {
    var src = document.getElementById('fs-' + id);
    if (!src) return;
    content.innerHTML = src.innerHTML;
    titleEl.textContent = label;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
    /* Re-initialise Lucide icons injected into the modal */
    if (window.lucide) window.lucide.createIcons({ scope: content });
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    content.innerHTML = '';
  }

  /* Open via the expand button */
  document.querySelectorAll('.preview-expand-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var frame = btn.closest('.preview-frame');
      openModal(frame.dataset.componentId, frame.dataset.componentLabel);
    });
  });

  /* Also open when clicking directly on the preview frame thumbnail */
  document.querySelectorAll('.preview-frame').forEach(function (frame) {
    frame.addEventListener('click', function () {
      openModal(frame.dataset.componentId, frame.dataset.componentLabel);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });

})();
</script>
